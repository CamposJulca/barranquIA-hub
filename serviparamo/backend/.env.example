# ServiPáramo Backend — variables de entorno
# Copia este archivo a .env y ajusta los valores

SECRET_KEY=cambia-esto-por-una-clave-segura
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos PostgreSQL (exclusiva de ServiPáramo)
DB_NAME=serviparamo
DB_USER=serviparamo
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ERP SQL Server
SERVIPARAMO_ERP_PASS=

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

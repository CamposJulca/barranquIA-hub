# ============================================================
# BarranquIA Hub — Variables de entorno
# Copiar este archivo a .env y ajustar los valores reales.
# El archivo .env es ignorado por git (.gitignore).
# ============================================================

# ── PostgreSQL — superusuario del contenedor ─────────────────────────────────
# La BD barranquia_hub es la del hub central.
# El script shared/postgres/init.sql crea automáticamente las BDs de
# serviparamo, avantika y joz con sus usuarios dedicados.
POSTGRES_DB=barranquia_hub
POSTGRES_USER=barranquia
POSTGRES_PASSWORD=Barranquia2024Hub

# ── Hub Backend (Django central — puerto 8005) ────────────────────────────────
DB_NAME=barranquia_hub
DB_USER=barranquia
DB_PASSWORD=Barranquia2024Hub
DB_HOST=postgres
DB_PORT=5432
SECRET_KEY=cambia-esta-clave-hub-antes-de-produccion
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,barranquia-hub.ngrok.io,192.168.0.101
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# ── ServiPáramo Backend (Django autónomo — puerto 8001) ───────────────────────
SERVIPARAMO_DB_USER=serviparamo
SERVIPARAMO_DB_PASSWORD=serviparamo2024
SERVIPARAMO_SECRET_KEY=cambia-esta-clave-serviparamo-antes-de-produccion
SERVIPARAMO_ERP_HOST=ts1.serviparamo.com.co
SERVIPARAMO_ERP_PORT=1433
SERVIPARAMO_ERP_DB=PRUEBA
SERVIPARAMO_ERP_PASS=reemplazar_con_contraseña_real

# ── Avantika Backend (Django autónomo — puerto 8002) ─────────────────────────
AVANTIKA_DB_USER=avantika
AVANTIKA_DB_PASSWORD=avantika2024
AVANTIKA_SECRET_KEY=cambia-esta-clave-avantika-antes-de-produccion

# ── Joz Backend (Django autónomo — puerto 8003) ───────────────────────────────
JOZ_DB_USER=joz
JOZ_DB_PASSWORD=joz2024
JOZ_SECRET_KEY=cambia-esta-clave-joz-antes-de-produccion

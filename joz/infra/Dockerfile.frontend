FROM node:20-alpine AS builder

WORKDIR /app

COPY joz/frontend/package*.json ./
RUN npm ci

COPY joz/frontend/ .

ARG VITE_API_URL=""
ARG VITE_API_TIMEOUT=15000
ENV VITE_API_URL=${VITE_API_URL} \
    VITE_API_TIMEOUT=${VITE_API_TIMEOUT}

RUN npm run build

FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY joz/infra/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
